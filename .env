# ⚠️ 이 프로젝트는 로컬 환경에서 실행됩니다
# ⚠️ This project runs in local environment only
# Content Automation Studio - Local Development Configuration

# =============================================================================
# Flask Configuration (Local Development)
# =============================================================================
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=local-development-secret-key-change-if-needed
DEBUG=True

# Server Configuration (Local)
HOST=0.0.0.0
PORT=5000

# =============================================================================
# Database Configuration (Local)
# =============================================================================
# Local SQLite database
DATABASE_URL=sqlite:///content_automation.db

# Redis Configuration (if Redis is running locally)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AI Service API Keys
# =============================================================================
# ⚠️ v:\API_Keys_and_Tokens.csv 파일에서 실제 API 키들을 복사해주세요
# ⚠️ Copy actual API keys from v:\API_Keys_and_Tokens.csv

# Google Cloud AI / Vertex AI
GOOGLE_AI_API_KEY=your-google-ai-api-key-here
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OpenAI GPT-4
OPENAI_API_KEY=your-openai-api-key-here

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# =============================================================================
# Publishing Platform Configuration
# =============================================================================

# Tistory Open API
TISTORY_ACCESS_TOKEN=your-tistory-access-token-here
TISTORY_BLOG_NAME=your-tistory-blog-name
TISTORY_APP_KEY=your-tistory-app-key

# Naver Blog / Naver Developers
NAVER_CLIENT_ID=your-naver-client-id-here
NAVER_CLIENT_SECRET=your-naver-client-secret-here
NAVER_BLOG_ID=your-naver-blog-id

# =============================================================================
# AI Development Partner Configuration (Local Ollama)
# =============================================================================

# Ollama Configuration (for Gemma 3)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:7b

# Claude CLI Configuration (if installed locally)
CLAUDE_CLI_PATH=claude
CLAUDE_API_KEY=your-claude-api-key-here

# =============================================================================
# Local Development Settings
# =============================================================================

# Development tools
FLASK_DEBUG_TOOLBAR=True
FLASK_PROFILER=False

# Logging for local development
LOG_LEVEL=DEBUG
LOG_FILE=logs/app.log

# Security for local development (relaxed)
SESSION_COOKIE_SECURE=False
SESSION_COOKIE_HTTPONLY=True

# CORS for local development
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5000,http://127.0.0.1:5000

# =============================================================================
# Feature Flags (All Enabled for Local Development)
# =============================================================================

# Enable all features locally
ENABLE_AI_CONTENT_GENERATION=True
ENABLE_TISTORY_PUBLISHING=True
ENABLE_NAVER_PUBLISHING=True
ENABLE_AI_DEVELOPMENT_PARTNER=True
ENABLE_ANALYTICS=True

# =============================================================================
# Performance Configuration (Local)
# =============================================================================

# Relaxed rate limiting for development
RATELIMIT_ENABLED=False
RATELIMIT_DEFAULT=1000/hour

# Cache Configuration
CACHE_TYPE=simple
CACHE_DEFAULT_TIMEOUT=300

# =============================================================================
# File Storage (Local)
# =============================================================================

# Local file storage
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216  # 16MB

# =============================================================================
# Local Development Only
# =============================================================================

# Set to True to force local mode
LOCAL_MODE_ONLY=True

# Disable external API calls for testing
MOCK_EXTERNAL_APIS=False

# Development server settings
TESTING=False

# =============================================================================
# GPU Acceleration Settings
# =============================================================================

# Enable GPU acceleration if available
ENABLE_GPU_ACCELERATION=True

# PyTorch CUDA settings
CUDA_VISIBLE_DEVICES=0

# Ollama GPU settings
OLLAMA_GPU_LAYERS=999