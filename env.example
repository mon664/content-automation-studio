# Content Automation Studio Environment Configuration
# Copy this file to .env and fill in your actual API keys and settings

# =============================================================================
# Flask Configuration
# =============================================================================
FLASK_APP=backend/app.py
FLASK_ENV=development
SECRET_KEY=your-secret-key-here-change-in-production
DEBUG=True

# =============================================================================
# Database Configuration
# =============================================================================
# Use SQLite for development, PostgreSQL for production
DATABASE_URL=sqlite:///content_automation.db
# DATABASE_URL=postgresql://username:password@localhost:5432/content_automation

# Redis Configuration (for caching and task queue)
REDIS_URL=redis://localhost:6379/0

# =============================================================================
# AI Service API Keys
# =============================================================================

# Google Cloud AI / Vertex AI
GOOGLE_AI_API_KEY=your-google-ai-api-key
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1

# OpenAI GPT-4
OPENAI_API_KEY=your-openai-api-key

# Anthropic Claude
ANTHROPIC_API_KEY=your-anthropic-api-key

# =============================================================================
# Publishing Platform Configuration
# =============================================================================

# Tistory Open API
TISTORY_ACCESS_TOKEN=your-tistory-access-token
TISTORY_BLOG_NAME=your-tistory-blog-name
TISTORY_APP_KEY=your-tistory-app-key

# Naver Blog / Naver Developers
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
NAVER_BLOG_ID=your-naver-blog-id

# =============================================================================
# File Storage Configuration
# =============================================================================

# AWS S3 (Optional - for file storage)
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=your-s3-bucket-name
AWS_S3_REGION=us-east-1

# WebDAV Configuration (Alternative file storage)
WEBDAV_URL=https://your-webdav-server.com/remote.php/dav/files/username/
WEBDAV_USERNAME=your-webdav-username
WEBDAV_PASSWORD=your-webdav-password

# =============================================================================
# AI Development Partner Configuration
# =============================================================================

# Ollama Configuration (for Gemma 3)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma:7b

# Claude CLI Configuration
CLAUDE_CLI_PATH=/usr/local/bin/claude
CLAUDE_API_KEY=your-claude-api-key

# =============================================================================
# Email Configuration (for notifications)
# =============================================================================

# SMTP Configuration
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-app-password

# =============================================================================
# Security Configuration
# =============================================================================

# Session Configuration
SESSION_TIMEOUT=3600
SESSION_COOKIE_SECURE=True
SESSION_COOKIE_HTTPONLY=True

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8000

# =============================================================================
# Analytics and Monitoring
# =============================================================================

# Google Analytics
GA_TRACKING_ID=your-ga-tracking-id

# Sentry (Error tracking)
SENTRY_DSN=your-sentry-dsn

# =============================================================================
# Development Tools
# =============================================================================

# Enable debug toolbar
FLASK_DEBUG_TOOLBAR=False

# Enable profiling
FLASK_PROFILER=False

# =============================================================================
# Production Configuration
# =============================================================================
# Set these values to True in production
PRODUCTION=False
SSL_DISABLE=False

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# =============================================================================
# Feature Flags
# =============================================================================

# Enable/Disable specific features
ENABLE_AI_CONTENT_GENERATION=True
ENABLE_TISTORY_PUBLISHING=True
ENABLE_NAVER_PUBLISHING=True
ENABLE_AI_DEVELOPMENT_PARTNER=True
ENABLE_ANALYTICS=True

# =============================================================================
# Performance Configuration
# =============================================================================

# Rate limiting
RATELIMIT_ENABLED=True
RATELIMIT_DEFAULT=200/hour

# Cache Configuration
CACHE_TYPE=redis
CACHE_DEFAULT_TIMEOUT=300

# =============================================================================
# External Service URLs
# =============================================================================

# Base URLs for external services
TISTORY_API_BASE_URL=https://www.tistory.com/apis
NAVER_API_BASE_URL=https://openapi.naver.com

# =============================================================================
# Docker Configuration
# =============================================================================
# These values are used in Docker environment
DOCKER_POSTGRES_HOST=postgres
DOCKER_POSTGRES_PORT=5432
DOCKER_POSTGRES_DB=content_automation
DOCKER_POSTGRES_USER=postgres
DOCKER_POSTGRES_PASSWORD=postgres

DOCKER_REDIS_HOST=redis
DOCKER_REDIS_PORT=6379
DOCKER_REDIS_DB=0

# =============================================================================
# Additional Settings
# =============================================================================

# Maximum file upload size (in bytes)
MAX_CONTENT_LENGTH=16777216  # 16MB

# Default language and timezone
DEFAULT_LANGUAGE=ko
TIMEZONE=Asia/Seoul

# Content generation settings
DEFAULT_CONTENT_LENGTH=2000
MAX_CONTENT_LENGTH=5000
GENERATION_TIMEOUT=60

# AI model settings
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=4000
AI_TOP_P=0.9