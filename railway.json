{
  "build": {
    "builder": "NIXPACKS"
  },
  "deploy": {
    "healthcheckPath": "/api/health",
    "healthcheckTimeout": 300,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  },
  "headers": {
    "/*": {
      "Content-Security-Policy": null,
      "X-Content-Security-Policy": null,
      "X-WebKit-CSP": null
    }
  }
}